---
// --- 1. 数据获取与处理 ---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

// 获取所有博客文章并按时间倒序排列
const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 提取所有文章中不重复的标签（假设你的 Markdown frontmatter 中有 tags 字段）
const allTags = [
	...new Set(posts.flatMap((post) => post.data.tags || ["默认"])),
];
---

<BaseLayout title="博客" description="我的全部文章">
	<div class="blog-dashboard">
		<div class="tools-bar">
			<div class="search-box">
				<svg
					viewBox="0 0 24 24"
					width="20"
					height="20"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					><circle cx="11" cy="11" r="8"></circle><line
						x1="21"
						y1="21"
						x2="16.65"
						y2="16.65"></line></svg
				>
				<input
					type="text"
					id="searchInput"
					placeholder="按标题或内容搜索..."
				/>
			</div>

			<button id="filterToggleBtn" class="filter-btn">
				<svg
					viewBox="0 0 24 24"
					width="18"
					height="18"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					><polygon
						points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"
					></polygon></svg
				>
				筛选
			</button>
		</div>

		<div id="filterModal" class="filter-modal hidden glass-panel">
			<div class="filter-section">
				<h3>按标签筛选</h3>
				<div class="tag-list" id="tagFilterList">
					<button class="tag-btn active" data-tag="all">全部</button>
					{
						allTags.map((tag) => (
							<button class="tag-btn" data-tag={tag}>
								{tag}
							</button>
						))
					}
				</div>
			</div>
		</div>

		<ul class="post-list" id="postList">
			{
				posts.map((post) => (
					// 在 HTML 元素上绑定 data- 属性，方便后续 JS 读取和过滤
					<li
						class="post-item"
						data-title={post.data.title.toLowerCase()}
						data-desc={post.data.description.toLowerCase()}
						data-tags={(post.data.tags || ["默认"]).join(",")}
					>
						<a href={`/blog/blog/${post.id}/`}>
							<h2 class="title">{post.data.title}</h2>
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<p class="excerpt">{post.data.description}</p>
							<div class="post-tags">
								{(post.data.tags || ["默认"]).map((tag) => (
									<span class="tag-badge">{tag}</span>
								))}
							</div>
						</a>
					</li>
				))
			}
		</ul>

		<div id="noResults" class="hidden no-results">
			没有找到匹配的文章 🥲
		</div>
	</div>
</BaseLayout>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const searchInput = document.getElementById("searchInput");
		const filterToggleBtn = document.getElementById("filterToggleBtn");
		const filterModal = document.getElementById("filterModal");
		const postItems = document.querySelectorAll(".post-item");
		const tagBtns = document.querySelectorAll(".tag-btn");
		const noResults = document.getElementById("noResults");

		let currentSearchTerm = "";
		let currentTag = "all";

		// 1. 切换筛选面板显隐
		filterToggleBtn.addEventListener("click", () => {
			filterModal.classList.toggle("hidden");
		});

		// 2. 核心过滤逻辑
		const filterPosts = () => {
			let visibleCount = 0;

			postItems.forEach((item) => {
				const title = item.getAttribute("data-title");
				const desc = item.getAttribute("data-desc");
				const tags = item.getAttribute("data-tags");

				// 匹配搜索词
				const matchesSearch =
					title.includes(currentSearchTerm) ||
					desc.includes(currentSearchTerm);
				// 匹配标签
				const matchesTag =
					currentTag === "all" ||
					tags.split(",").includes(currentTag);

				if (matchesSearch && matchesTag) {
					item.style.display = "block"; // 显示
					visibleCount++;
				} else {
					item.style.display = "none"; // 隐藏
				}
			});

			// 处理无结果的状态
			noResults.style.display = visibleCount === 0 ? "block" : "none";
		};

		// 3. 监听输入框
		searchInput.addEventListener("input", (e) => {
			currentSearchTerm = e.target.value.toLowerCase();
			filterPosts();
		});

		// 4. 监听标签点击
		tagBtns.forEach((btn) => {
			btn.addEventListener("click", (e) => {
				// 更新激活样式
				tagBtns.forEach((b) => b.classList.remove("active"));
				e.target.classList.add("active");

				// 执行过滤
				currentTag = e.target.getAttribute("data-tag");
				filterPosts();
			});
		});
	});
</script>

<style>
	/* 顶部工具栏布局 */
	.tools-bar {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	/* 搜索框样式 */
	.search-box {
		flex: 1;
		display: flex;
		align-items: center;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		padding: 0.5rem 1rem;
		color: var(--text-muted);
	}
	.search-box input {
		background: transparent;
		border: none;
		outline: none;
		color: var(--text-primary);
		width: 100%;
		margin-left: 0.8rem;
		font-size: 1rem;
	}

	/* 筛选按钮 */
	.filter-btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--bg-sidebar);
		color: var(--text-primary);
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 0 1.2rem;
		border-radius: 8px;
		cursor: pointer;
		transition: all 0.2s;
	}
	.filter-btn:hover {
		background: var(--accent);
		color: #fff;
	}

	/* 筛选面板 (磨砂玻璃) */
	.glass-panel {
		background: rgba(30, 41, 59, 0.8);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		padding: 1.5rem;
		margin-bottom: 1.5rem;
		animation: fadeIn 0.2s ease-out;
	}
	.hidden {
		display: none !important;
	}

	.filter-section h3 {
		margin-top: 0;
		font-size: 0.9rem;
		color: var(--text-muted);
		margin-bottom: 1rem;
	}

	/* 标签按钮 */
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag-btn {
		background: transparent;
		border: 1px solid var(--text-muted);
		color: var(--text-muted);
		padding: 0.3rem 0.8rem;
		border-radius: 20px;
		font-size: 0.85rem;
		cursor: pointer;
		transition: all 0.2s;
	}
	.tag-btn.active,
	.tag-btn:hover {
		background: var(--accent);
		color: #fff;
		border-color: var(--accent);
	}

	/* 文章列表与卡片 */
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.post-item a {
		display: block;
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		text-decoration: none;
		transition:
			transform 0.2s,
			background 0.2s;
	}
	.post-item a:hover {
		transform: translateY(-2px);
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--accent);
	}

	/* 卡片内部排版 */
	.title {
		margin: 0 0 0.5rem 0;
		font-size: 1.4rem;
		color: var(--text-primary);
	}
	.date {
		margin: 0 0 1rem 0;
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.excerpt {
		color: var(--text-muted);
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.post-tags {
		display: flex;
		gap: 0.5rem;
	}
	.tag-badge {
		background: rgba(6, 182, 212, 0.1);
		color: var(--accent);
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
		font-size: 0.8rem;
	}

	.no-results {
		text-align: center;
		padding: 3rem;
		color: var(--text-muted);
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(-5px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
