---
import HeaderLink from "./HeaderLink.astro";
---

<header class="glass-header">
	<nav>
		<div class="internal-links">
			<HeaderLink href="/blog">Home</HeaderLink>
			<HeaderLink href="/blog/blog">Blog</HeaderLink>
			<HeaderLink href="/blog/project">Project</HeaderLink>
		</div>
	</nav>
</header>

<style>
	.glass-header {
		/* --- 核心：磨砂玻璃特效 --- */
		background: rgba(15, 23, 42, 0.65); /* 使用半透明的主背景色 */
		backdrop-filter: blur(12px); /* 高斯模糊，制造磨砂感 */
		-webkit-backdrop-filter: blur(12px); /* 兼容 Safari 浏览器 */
		border-bottom: 1px solid rgba(255, 255, 255, 0.05); /* 极细的高光底边，提升立体感 */

		/* --- 布局与吸顶效果 --- */
		position: sticky;
		top: 0;
		z-index: 50; /* 确保向下滚动时，顶栏始终盖在内容上方 */
		padding: 1rem 0;
		margin-bottom: 2rem;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: flex-end; /* 让菜单靠右对齐，更显现代感 */
	}

	.internal-links {
		display: flex;
		gap: 2rem; /* 加大两个按钮之间的间距 */
	}

	/* 使用 :global 穿透修改子组件 HeaderLink 的 a 标签样式 */
	.internal-links :global(a) {
		color: var(--text-muted);
		text-decoration: none;
		font-weight: 500;
		font-size: 1.1rem;
		padding: 0.5rem 0;
		border-bottom: 2px solid transparent;
		transition: all 0.3s ease; /* 增加平滑的过渡动画 */
	}

	/* 鼠标悬浮或当前页面的激活状态 */
	.internal-links :global(a:hover),
	.internal-links :global(a.active) {
		color: var(--text-primary);
		border-bottom-color: var(--accent); /* 底部出现青色高光指示条 */
	}
</style>
