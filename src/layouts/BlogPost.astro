---
// --- 1. 引入依赖 ---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

// 获取传入的文章元数据
type Props = CollectionEntry<"blog">["data"];
const { title, description, pubDate, updatedDate, heroImage, tags } =
	Astro.props;
---

<BaseLayout title={title} description={description}>
	<article class="prose-container">
		{
			heroImage && (
				<div class="hero-image">
					<img width={1020} height={510} src={heroImage.src} alt="" />
				</div>
			)
		}

		<div class="prose">
			<div class="title-header">
				<div class="date">
					<FormattedDate date={pubDate} />
					{
						updatedDate && (
							<div class="last-updated-on">
								(最后更新于 <FormattedDate date={updatedDate} />
								)
							</div>
						)
					}
				</div>
				<h1>{title}</h1>

				{
					tags && (
						<div class="tags">
							{tags.map((tag) => (
								<span class="tag-badge">{tag}</span>
							))}
						</div>
					)
				}
				<hr class="divider" />
			</div>

			<div class="markdown-content">
				<slot />
			</div>
		</div>
	</article>
</BaseLayout>

<style>
	/* 容器定宽居中，制造高级留白感 */
	.prose-container {
		max-width: 800px; /* 限制最宽 800px，太宽阅读容易视觉疲劳 */
		margin: 0 auto;
		padding: 0 1rem 4rem 1rem;
	}

	/* 头图样式 */
	.hero-image {
		width: 100%;
		margin-bottom: 3rem;
	}
	.hero-image img {
		display: block;
		margin: 0 auto;
		border-radius: 16px;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
		object-fit: cover;
	}

	/* 标题区域排版 */
	.title-header {
		margin-bottom: 3rem;
		text-align: center; /* 标题居中更显庄重 */
	}
	.title-header h1 {
		font-size: 2.8rem;
		line-height: 1.3;
		margin: 1rem 0;
		color: var(--text-primary);
		font-weight: 700;
	}
	.date {
		font-size: 0.95rem;
		color: var(--text-muted);
		letter-spacing: 1px;
	}

	/* 标签样式复用之前设计的青色微光 */
	.tags {
		display: flex;
		justify-content: center;
		gap: 0.8rem;
		margin-top: 1.5rem;
	}
	.tag-badge {
		background: rgba(6, 182, 212, 0.1);
		color: var(--accent);
		padding: 0.3rem 0.8rem;
		border-radius: 20px;
		font-size: 0.85rem;
		border: 1px solid rgba(6, 182, 212, 0.2);
	}

	/* 优雅的分割线 */
	.divider {
		border: 0;
		height: 1px;
		background: linear-gradient(
			to right,
			transparent,
			rgba(255, 255, 255, 0.1),
			transparent
		);
		margin-top: 2.5rem;
	}
</style>

<style is:global>
	/* 因为 Markdown 生成的元素不受上面局部 style 的控制，所以必须用 is:global */
	.markdown-content {
		font-size: 1.15rem; /* 增大基础字号，提升阅读体验 */
		line-height: 1.85; /* 增加行高，让文字"呼吸" */
		color: #cbd5e1; /* 柔和的浅灰白色，避免纯白刺眼 */
	}

	/* 段落留白 */
	.markdown-content p {
		margin-bottom: 1.8rem;
	}

	/* 标题层级美化 */
	.markdown-content h2,
	.markdown-content h3,
	.markdown-content h4 {
		color: var(--text-primary);
		margin-top: 3rem;
		margin-bottom: 1.2rem;
		font-weight: 600;
	}
	.markdown-content h2 {
		font-size: 1.8rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: 0.5rem;
	}
	.markdown-content h3 {
		font-size: 1.5rem;
	}

	/* 超链接样式 */
	.markdown-content a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 4px; /* 让下划线离文字远一点，更美观 */
	}
	.markdown-content a:hover {
		color: #fff;
	}

	/* 引用块 (Blockquote) 美化 */
	.markdown-content blockquote {
		border-left: 4px solid var(--accent);
		background: rgba(255, 255, 255, 0.03);
		margin: 2rem 0;
		padding: 1rem 1.5rem;
		border-radius: 0 8px 8px 0;
		font-style: italic;
		color: var(--text-muted);
	}

	/* 行内代码和代码块美化 */
	.markdown-content code {
		background: rgba(255, 255, 255, 0.1);
		padding: 0.2rem 0.4rem;
		border-radius: 4px;
		font-size: 0.9em;
		color: #e2e8f0;
		font-family: monospace;
	}
	.markdown-content pre {
		padding: 1.5rem;
		border-radius: 12px;
		overflow-x: auto;
		margin: 2rem 0;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}
	.markdown-content pre code {
		background: transparent;
		padding: 0;
		color: inherit;
	}

	/* 列表留白 */
	.markdown-content ul,
	.markdown-content ol {
		margin-bottom: 1.8rem;
		padding-left: 1.5rem;
	}
	.markdown-content li {
		margin-bottom: 0.5rem;
	}
</style>
